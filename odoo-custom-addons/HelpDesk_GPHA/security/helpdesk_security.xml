<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <!-- how the groups appear in the settings pane -->
    <record id="module_helpdesk_category" model="ir.module.category">
        <field name="name">Helpdesk</field>
        <field name="description">Manage access to the Helpdesk Problem Log</field>
        <field name="sequence">100</field>
    </record>

    <!-- Role 1: User — can create tickets and see only their own reported tickets -->
    <record id="group_helpdesk_user" model="res.groups">
        <field name="name">Helpdesk User</field>
        <field name="category_id" ref="module_helpdesk_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Role 2: Coordinator — triages tickets and assigns them to assignees -->
    <record id="group_helpdesk_coordinator" model="res.groups">
        <field name="name">Helpdesk Coordinator</field>
        <field name="category_id" ref="module_helpdesk_category"/>
    </record>

    <!-- Role 3: Assignee — works only on tickets assigned to them -->
    <record id="group_helpdesk_assignee" model="res.groups">
        <field name="name">Helpdesk Assignee</field>
        <field name="category_id" ref="module_helpdesk_category"/>
    </record>

    <!-- Role 4: Manager — sees everything and manages configuration -->
    <record id="group_helpdesk_manager" model="res.groups">
        <field name="name">Helpdesk Manager</field>
        <field name="category_id" ref="module_helpdesk_category"/>
    </record>

    <!-- RECORD RULES: helpdesk.ticket -->
    <record id="rule_helpdesk_ticket_user_own" model="ir.rule">
        <field name="name">Helpdesk Ticket: Users see their own reported tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[('reporter_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_helpdesk_ticket_assignee_own" model="ir.rule">
        <field name="name">Helpdesk Ticket: Assignees see assigned tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[('assigned_to', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_assignee'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_helpdesk_ticket_coordinator_all" model="ir.rule">
        <field name="name">Helpdesk Ticket: Coordinators manage all tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_coordinator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_helpdesk_ticket_manager_all" model="ir.rule">
        <field name="name">Helpdesk Ticket: Managers see everything</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- RECORD RULES: helpdesk.ticket.log -->
    <record id="rule_helpdesk_log_user_own" model="ir.rule">
        <field name="name">Helpdesk Log: Users see their own logs</field>
        <field name="model_id" ref="model_helpdesk_ticket_log"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_helpdesk_log_assignee_own" model="ir.rule">
        <field name="name">Helpdesk Log: Assignees see logs they created</field>
        <field name="model_id" ref="model_helpdesk_ticket_log"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_assignee'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_helpdesk_log_coordinator_all" model="ir.rule">
        <field name="name">Helpdesk Log: Coordinators see all logs</field>
        <field name="model_id" ref="model_helpdesk_ticket_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_coordinator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_helpdesk_log_manager_all" model="ir.rule">
        <field name="name">Helpdesk Log: Managers see all logs</field>
        <field name="model_id" ref="model_helpdesk_ticket_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</data>
</odoo>