<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <record id="action_helpdesk_ticket" model="ir.actions.act_window">
        <field name="name">Problem Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No tickets yet!</p>
            <p>Log your first problem ticket to get started.</p>
        </field>
    </record>

    <!-- Root menu: visible to everyone so users can see their 'My Tickets' under it -->
    <menuitem id="menu_helpdesk_root" name="Helpdesk" web_icon="helpdesk_problem_log,static/description/icon.png" sequence="50"/>

    <menuitem id="menu_helpdesk_tickets" name="Tickets" parent="menu_helpdesk_root" sequence="10"/>

    <menuitem id="menu_helpdesk_all_tickets" name="All Tickets" parent="menu_helpdesk_tickets" action="action_helpdesk_ticket" sequence="10" groups="group_helpdesk_coordinator,group_helpdesk_manager"/>

    <!-- User role: My Tickets now lives under the Helpdesk root -->
    <record id="action_helpdesk_my_reported_tickets" model="ir.actions.act_window">
        <field name="name">My Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('reporter_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_open': 1}</field>
        <field name="help" type="html"><p class="o_view_nocontent_smiling_face">No tickets reported by you yet!</p></field>
    </record>

    <menuitem id="menu_helpdesk_my_tickets" name="My Tickets" parent="menu_helpdesk_root" action="action_helpdesk_my_reported_tickets" sequence="20" groups="group_helpdesk_user"/>

    <!-- Assignee role: tickets assigned to them -->
    <record id="action_helpdesk_my_assigned_tickets" model="ir.actions.act_window">
        <field name="name">My Assigned Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('assigned_to', '=', uid)]</field>
        <field name="context">{'search_default_filter_open': 1}</field>
        <field name="help" type="html"><p class="o_view_nocontent_smiling_face">No tickets assigned to you yet!</p></field>
    </record>

    <menuitem id="menu_helpdesk_my_assigned" name="My Assigned" parent="menu_helpdesk_tickets" action="action_helpdesk_my_assigned_tickets" sequence="25" groups="group_helpdesk_assignee,group_helpdesk_coordinator,group_helpdesk_manager"/>

    <!-- Managers only -->
    <menuitem id="menu_helpdesk_config" name="Configuration" parent="menu_helpdesk_root" groups="group_helpdesk_manager" sequence="90"/>

    <record id="action_helpdesk_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">helpdesk.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_helpdesk_category" name="Categories" parent="menu_helpdesk_config" action="action_helpdesk_category" sequence="10"/>

    <record id="action_helpdesk_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">helpdesk.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_helpdesk_tag" name="Tags" parent="menu_helpdesk_config" action="action_helpdesk_tag" sequence="20"/>


    <record id="action_helpdesk_office" model="ir.actions.act_window">
        <field name="name">Location/Office</field>
        <field name="res_model">helpdesk.office.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_helpdesk_office" name="Location/Office" parent="menu_helpdesk_config" action="action_helpdesk_office" groups="group_helpdesk_manager" sequence="5"/>



</data>
</odoo>
